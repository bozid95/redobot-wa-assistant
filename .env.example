TZ=Asia/Jakarta

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
EVOLUTION_DB_NAME=evolution
APP_DB_NAME=app

# Backend / app
PORT=4000
JWT_SECRET=replace-with-a-long-random-jwt-secret
COOKIE_SECRET=replace-with-a-long-random-cookie-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-dashboard-password
ADMIN_NAME=Admin
DEFAULT_LANGUAGE=id
UPLOAD_DIR=/app/uploads
KNOWLEDGE_DIR=/app/knowledge
TIKA_URL=http://tika:9998

# AI Provider
LLM_BASE_URL=https://ai.sumopod.com/v1
LLM_API_KEY=sk-change-me
CHAT_MODEL=replace-with-sumopod-chat-model
EMBEDDING_BASE_URL=https://ai.sumopod.com/v1
EMBEDDING_API_KEY=sk-change-me
EMBEDDING_MODEL=replace-with-sumopod-embedding-model
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=wa_kb
QDRANT_VECTOR_SIZE=1536
RAG_SCORE_THRESHOLD=0.45
RAG_TOP_K=5
RAG_MAX_CONTEXT_CHUNKS=3
CHUNK_TARGET_TOKENS=700
CHUNK_OVERLAP_TOKENS=100

# Evolution API
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE_NAME=wa-rag-bot
EVOLUTION_SERVER_URL=http://localhost:8080
EVOLUTION_WEBHOOK_URL=http://backend:4000/webhooks/evolution

# Frontend
VITE_API_BASE_URL=http://localhost:4000
