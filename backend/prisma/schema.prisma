generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConversationStatus {
  open
  takeover
  closed
}

enum MessageRole {
  user
  assistant
  admin
  system
}

enum MessageSource {
  evolution
  rag
  fallback
  manual_reply
  router_greeting
  router_clarify
  router_thanks
  takeover
}

enum LeadReason {
  no_match
  low_confidence
  llm_error
  system_error
}

enum LeadStatus {
  open
  closed
}

enum KnowledgeStatus {
  pending
  indexed
  error
}

enum WaInstanceStatus {
  not_created
  connecting
  connected
  disconnected
  error
}

enum UserRole {
  platform_admin
  tenant_admin
  tenant_staff
}

model Tenant {
  id                   Int                   @id @default(autoincrement())
  name                 String
  slug                 String                @unique
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  users                AppUser[]
  waInstances          WaInstance[]
  conversations        Conversation[]
  conversationMessages ConversationMessage[]
  knowledgeSources     KnowledgeSource[]
  unansweredLeads      UnansweredLead[]
  processedMessages    ProcessedMessage[]
  ragConfig            RagConfig?

  @@map("tenants")
}

model AssistantTemplate {
  id            Int         @id @default(autoincrement())
  name          String
  slug          String      @unique
  description   String?
  assistantFlow Json        @map("assistant_flow")
  isSystem      Boolean     @default(false) @map("is_system")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  ragConfigs    RagConfig[]

  @@map("assistant_templates")
}

model AppUser {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String    @default("Admin")
  role         UserRole  @default(tenant_staff)
  tenantId     Int?      @map("tenant_id")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  tenant       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@map("app_users")
}

model WaInstance {
  id              Int              @id @default(autoincrement())
  tenantId        Int?             @unique @map("tenant_id")
  instanceName    String           @unique @map("instance_name")
  phoneNumber     String?          @map("phone_number")
  status          WaInstanceStatus @default(not_created)
  qrCodeBase64    String?          @map("qr_code_base64")
  lastError       String?          @map("last_error")
  lastConnectedAt DateTime?        @map("last_connected_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@map("wa_instances")
}

model Conversation {
  id                   Int                   @id @default(autoincrement())
  tenantId             Int?                  @map("tenant_id")
  phone                String
  customerName         String?               @map("customer_name")
  status               ConversationStatus    @default(open)
  leadStage            String                @default("new") @map("lead_stage")
  leadScore            Int                   @default(0) @map("lead_score")
  handoffSuggested     Boolean               @default(false) @map("handoff_suggested")
  paymentRequested     Boolean               @default(false) @map("payment_requested")
  paymentProofReceived Boolean               @default(false) @map("payment_proof_received")
  takeoverEnabled      Boolean               @default(false) @map("takeover_enabled")
  lastMessageAt        DateTime              @default(now()) @map("last_message_at")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  tenant               Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  messages             ConversationMessage[]
  leads                UnansweredLead[]

  @@unique([tenantId, phone])
  @@map("conversations")
}

model ConversationMessage {
  id             Int           @id @default(autoincrement())
  tenantId       Int?          @map("tenant_id")
  conversationId Int           @map("conversation_id")
  phone          String
  role           MessageRole
  source         MessageSource @default(evolution)
  message        String
  messageId      String?       @map("message_id")
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at")
  tenant         Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("conversation_messages")
}

model KnowledgeSource {
  id            Int             @id @default(autoincrement())
  tenantId      Int?            @map("tenant_id")
  title         String
  content       String
  sourceType    String          @default("text") @map("source_type")
  sourcePath    String?         @map("source_path")
  status        KnowledgeStatus @default(pending)
  lastIndexedAt DateTime?       @map("last_indexed_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  tenant        Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@map("knowledge_sources")
}

model UnansweredLead {
  id             Int           @id @default(autoincrement())
  tenantId       Int?          @map("tenant_id")
  conversationId Int?          @map("conversation_id")
  phone          String
  question       String
  reason         LeadReason
  status         LeadStatus    @default(open)
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at")
  tenant         Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@map("unanswered_leads")
}

model ProcessedMessage {
  id        Int      @id @default(autoincrement())
  tenantId  Int?     @map("tenant_id")
  messageId String   @map("message_id")
  phone     String
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([tenantId, messageId])
  @@map("processed_messages")
}

model RagConfig {
  id                  Int      @id @default(autoincrement())
  tenantId            Int      @unique @map("tenant_id")
  assistantTemplateId Int?     @map("assistant_template_id")
  assistantName       String?  @map("assistant_name")
  businessContext     String?  @map("business_context")
  greetingMessage     String?  @map("greeting_message")
  clarifyMessage      String?  @map("clarify_message")
  fallbackMessage     String?  @map("fallback_message")
  thanksMessage       String?  @map("thanks_message")
  salesCtaNew         String?  @map("sales_cta_new")
  salesCtaInterested  String?  @map("sales_cta_interested")
  salesCtaHot         String?  @map("sales_cta_hot")
  salesCtaHandoff     String?  @map("sales_cta_handoff")
  systemPrompt        String?  @map("system_prompt")
  paymentPrompt       String?  @map("payment_prompt")
  scoreThreshold      Float?   @map("score_threshold")
  topK                Int?     @map("top_k")
  maxChunks           Int?     @map("max_chunks")
  chunkTargetTokens   Int?     @map("chunk_target_tokens")
  assistantFlow       Json?    @map("assistant_flow")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assistantTemplate   AssistantTemplate? @relation(fields: [assistantTemplateId], references: [id], onDelete: SetNull)

  @@map("rag_configs")
}
